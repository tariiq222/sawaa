# Backend API base URL — must point to the NestJS backend in production
NEXT_PUBLIC_API_URL=http://localhost:5200/api/v1

# Dev-only: auto-fill login form credentials in development builds
# These are NEVER embedded in production builds (see next.config.mjs)
NEXT_PUBLIC_DEV_EMAIL=admin@sawa.local
NEXT_PUBLIC_DEV_PASSWORD=change-me

# E2E Test flag (passed to the backend process, not used by Next.js directly)
# Set to true ONLY in CI E2E job. Refused in production.
E2E_TEST=false

# Moyasar browser-side publishable key. Never use a secret key in the dashboard.
NEXT_PUBLIC_MOYASAR_PLATFORM_PUBLISHABLE_KEY=pk_test_replace_me

# --- Sentry / GlitchTip error tracking ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=sawa-dashboard
SENTRY_URL=https://errors.webvue.pro/

# --- PostHog error tracking (browser-side) ---
# Leave empty to silently disable.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Single-company mode: no tenant subdomain routing. This value is kept only for
# legacy middleware compatibility and should remain localhost in local examples.
NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=localhost
