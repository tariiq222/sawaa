{
  "name": "backend",
  "version": "2.1.9",
  "private": true,
  "description": "Sawaa Backend v2 — NestJS + Bounded Contexts + Vertical Slices",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "pnpm run prisma:generate && TZ=Asia/Riyadh jest",
    "test:watch": "TZ=Asia/Riyadh jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "NODE_OPTIONS=\"--max-old-space-size=4096\" jest --config test/jest-e2e.json --json --outputFile=test-results-clients.json",
    "test:smoke": "jest --config test/jest-smoke.json --runInBand",
    "test:kiwi": "jest --json --outputFile=/tmp/jest-backend-unit.json || true && node ../../scripts/kiwi/kiwi-sync-manual-qa.mjs --jest /tmp/jest-backend-unit.json --tag backend --domain Backend --plan-name 'Sawaa / Backend / Unit' --plan-summary 'Automated Jest unit tests for apps/backend.'",
    "test:kiwi:e2e": "jest --config test/jest-e2e.json --json --outputFile=/tmp/jest-backend-e2e.json || true && node ../../scripts/kiwi/kiwi-sync-manual-qa.mjs --jest /tmp/jest-backend-e2e.json --tag backend-e2e --domain 'Backend E2E' --plan-name 'Sawaa / Backend / E2E' --plan-summary 'Jest E2E tests for apps/backend.'",
    "test:kiwi:all": "pnpm run test:kiwi && pnpm run test:kiwi:e2e",
    "test:e2e:cov": "NODE_OPTIONS=\"--max-old-space-size=4096\" jest --config test/jest-e2e.json --coverage --coverageReporters=text-summary --coverageReporters=html",
    "test:security": "jest --config test/jest-security.json --runInBand",
    "test:report": "py ../../data/test-reports/scripts/generate_html_report.py",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev && pnpm run prisma:hooks",
    "prisma:migrate:deploy": "prisma migrate deploy && pnpm run prisma:hooks",
    "prisma:hooks": "prisma db execute --file prisma/hooks/ensure_vector_indexes.sql",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "bootstrap:admin": "tsx prisma/bootstrap-admin.ts",
    "seed:sawa": "tsx prisma/seeds/sawa-customer.ts",
    "seed:sawa-clinic-services": "tsx prisma/seeds/sawa-clinic-services.ts",
    "seed:therapists": "tsx prisma/seeds/demo-therapists.ts",
    "seed:support-groups": "tsx prisma/seeds/demo-support-groups.ts",
    "reset:org-suspension": "tsx scripts/reset-org-suspension.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "openapi:snapshot": "WRITE_OPENAPI_SPEC=1 tsx -e \"require('./dist/main.js')\"",
    "openapi:build-and-snapshot": "pnpm run build && pnpm run openapi:snapshot",
    "check:openapi-coverage": "tsx scripts/check-openapi-coverage.ts",
    "backfill:counters": "tsx scripts/billing/recompute-all-counters.ts",
    "rekey:credentials": "tsx scripts/rekey-credentials.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.7.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sawaa/shared": "workspace:*",
    "@sentry/node": "^10.51.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^8.5.1",
    "file-type": "^22.0.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "libphonenumber-js": "^1.12.42",
    "minio": "^8.0.7",
    "nestjs-cls": "^4.5.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prisma": "^7.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
