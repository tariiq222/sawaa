// Platform BC — license validation, problem reports, integrations.
// SaaS-02g: ProblemReport, Integration scoped (NOT Organization/Membership/Vertical*).

enum ProblemReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ProblemReportType {
  BUG
  FEATURE_REQUEST
  OTHER
}

model ProblemReport {
  id          String              @id @default(uuid())
  reporterId  String
  type        ProblemReportType
  title       String
  description String
  status      ProblemReportStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status])
}

model Integration {
  id       String   @id @default(uuid())
  provider String   @unique
  config   Json
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Platform-level webhook dedup. Intentionally NOT in SCOPED_MODELS — Moyasar webhooks belong to Deqah, not a tenant.
model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String // 'MOYASAR_PLATFORM' | 'MOYASAR_TENANT'
  eventId     String
  eventType   String
  receivedAt  DateTime  @default(now())
  payloadHash String
  processedAt DateTime?
  result      String? // 'processed' | 'skipped_duplicate' | 'error'

  @@unique([provider, eventId])
  @@index([receivedAt])
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}
