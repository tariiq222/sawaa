# Sawa Production Environment — docker/.env.prod.example
#
# !! SINGLE-COMPANY SAWA CHECKLIST. Legacy Sawaa SaaS values below are kept only
# !! where changing live deployment identifiers could break an existing deploy.
#
# All keys marked [REQUIRED] must be set before the backend will boot.
# Keys marked [REQUIRED in prod] are enforced by Joi when NODE_ENV=production.
# Optional keys default to safe values if omitted.
#
# Copy to .env.prod (never commit .env.prod) and fill every [REQUIRED] value.
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.prod up -d
#
# Generate random secrets with:
#   openssl rand -base64 32   (for 32-byte keys, base64-encoded, length=44)
#   openssl rand -base64 64   (for JWT secrets)
#
# DRIFT CHECK: run `node scripts/ci/check-env-drift.mjs` to verify this file
# stays in sync with apps/backend/src/config/env.validation.ts.

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5200

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# [REQUIRED]
# CRITICAL — runtime MUST use the NOBYPASSRLS role (deqah_app), NOT the OWNER (deqah).
# The OWNER role is reserved for the migrate container only. Using OWNER here makes
# RLS policies effectively decorative because OWNER bypasses RLS unless FORCE is set
# AND we still want defense-in-depth. See docs/operations/p0-rls-cutover.md.
DATABASE_URL=postgresql://deqah_app:<APP_DB_PASSWORD>@deqah-database-jeprin:5432/deqah

# ── Docker / Postgres container vars (used by docker-compose, not Joi) ────────
POSTGRES_USER=sawaa
POSTGRES_PASSWORD=
POSTGRES_DB=sawaa

# ─── Postgres roles (RLS hardening 2026-05-09) ─────────────────────────────
# POSTGRES_USER / POSTGRES_PASSWORD: OWNER role used by the migrate container.
# APP_DB_USER / APP_DB_PASSWORD:     NOBYPASSRLS runtime role used by the
#                                    backend service. The role is created by
#                                    migration 20260509000000 with a placeholder
#                                    password — set the real password via
#                                    `ALTER ROLE deqah_app WITH PASSWORD '...'`
#                                    before flipping DATABASE_URL.
APP_DB_USER=deqah_app
APP_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Legacy Sawaa tenant-isolation hardening. Keep false for Sawa single-company
# mode unless a future reviewed migration reintroduces a tested RLS path.
RLS_GUC_INTERCEPTOR_ENABLED=false

# ── Redis ─────────────────────────────────────────────────────────────────────
# [REQUIRED]
REDIS_HOST=sawaa-redis-lby5cy
# [REQUIRED]
REDIS_PORT=6379
# optional
REDIS_PASSWORD=

# ── MinIO (object storage) ───────────────────────────────────────────────────
# [REQUIRED]
MINIO_ENDPOINT=sawaa-minio-w7ighg
# [REQUIRED]
MINIO_PORT=9000
# [REQUIRED]
MINIO_ACCESS_KEY=
# [REQUIRED]
MINIO_SECRET_KEY=
# [REQUIRED]
MINIO_BUCKET=sawaa
MINIO_USE_SSL=false

# ── JWT (Identity) ────────────────────────────────────────────────────────────
# [REQUIRED] — generate: openssl rand -base64 64
JWT_ACCESS_SECRET=
# [REQUIRED] — generate: openssl rand -base64 64
JWT_REFRESH_SECRET=
# [REQUIRED in prod] — generate: openssl rand -base64 64
# Dedicated OTP secret — must differ from JWT_ACCESS_SECRET
JWT_OTP_SECRET=
# [REQUIRED] — generate: openssl rand -base64 64
JWT_CLIENT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_CLIENT_ACCESS_TTL=15m
JWT_CLIENT_REFRESH_TTL=7d

# ── Encryption keys (32 raw bytes, base64-encoded — ASCII length MUST be 44) ──
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# [REQUIRED]
SMS_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
ZOOM_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
MOYASAR_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED]
EMAIL_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>
# [REQUIRED] — set RELAX_PROD_VALIDATION=true only during the initial boot window
# before Zoho credentials are available
ZOHO_PROVIDER_ENCRYPTION_KEY=<base64-32-bytes>

# ── Single-company tenancy ────────────────────────────────────────────────────
# Sawa is not operated as Sawaa SaaS. Keep enforcement off and pin all scoped
# rows to the fixed organization id unless/until code removes organizationId.
TENANT_ENFORCEMENT=off

# ── Super-admin password ──────────────────────────────────────────────────────
# [REQUIRED in prod] — min 16 chars; banned values: Admin@2026, admin, password
SUPER_ADMIN_PASSWORD=


# ── Authentica (OTP SMS provider) ─────────────────────────────────────────────
# [REQUIRED in prod] — https://portal.authentica.sa/settings/apikeys/
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# ── Legacy SaaS billing kill-switch ──────────────────────────────────────────
# These Sawaa SaaS subscription-billing variables are legacy for Sawa. Leave the
# keys blank and cron disabled unless a remaining compatibility path explicitly
# requires test credentials.
MOYASAR_PLATFORM_SECRET_KEY=
MOYASAR_PLATFORM_WEBHOOK_SECRET=
SAAS_TRIAL_DAYS=0
SAAS_GRACE_PERIOD_DAYS=0
BILLING_CRON_ENABLED=false
PLATFORM_DEFAULT_PLAN_SLUG=BASIC

# ── Platform tax invoice metadata ─────────────────────────────────────────────
# [REQUIRED] — replace 300000000000003 with real ZATCA VAT before live invoices
PLATFORM_VAT_NUMBER=300000000000003
# [REQUIRED]
PLATFORM_COMPANY_NAME_AR=دقّة لتقنية المعلومات
# [REQUIRED]
PLATFORM_COMPANY_NAME_EN=Sawaa Information Technology

# ── Public URLs ───────────────────────────────────────────────────────────────
# [REQUIRED in prod]
DASHBOARD_PUBLIC_URL=https://app.sawaa.net
# [REQUIRED in prod]
API_PUBLIC_URL=https://api.sawaa.net
# [REQUIRED in prod]
PUBLIC_WEBSITE_URL=https://sawaa.net

# ── Next.js build-time public env (docker-compose.prod.yml passes these as build args)
# [REQUIRED for dashboard build]
NEXT_PUBLIC_API_URL=https://api.sawaa.net/api/v1
# [REQUIRED for website build]
NEXT_PUBLIC_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (dashboard + mobile)
CORS_ORIGINS=https://app.sawaa.net,https://admin.sawaa.net

# ── Legacy super-admin host guard ─────────────────────────────────────────────
# The standalone SaaS admin app is legacy/removed for Sawa; keep narrow if any
# backend compatibility endpoint remains reachable.
ADMIN_HOSTS=admin.sawaa.net

# ── Zoho invoicing integration ────────────────────────────────────────────────
# Legacy comments may call this per-tenant; Sawa uses one organization context.
# Set RELAX_PROD_VALIDATION=true to make optional during initial boot
ZOHO_OAUTH_CLIENT_ID=<your-zoho-client-id>
ZOHO_OAUTH_CLIENT_SECRET=<your-zoho-client-secret>
ZOHO_OAUTH_REDIRECT_URI=https://api.sawaa.net/api/v1/integrations/zoho/callback
ZOHO_PLATFORM_ORGANIZATION_ID=
ZOHO_PLATFORM_REFRESH_TOKEN=
ZOHO_PLATFORM_DC=sa
ZOHO_PLATFORM_WEBHOOK_SECRET=
SMS_WEBHOOK_URL_BASE=https://api.sawaa.net

# ── AI (optional) ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Firebase / FCM (push notifications — optional) ────────────────────────────
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── SMTP (optional — Resend or other provider) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sawaa.net

# ── Escape hatch ─────────────────────────────────────────────────────────────
# Set to true ONLY during initial boot window before Zoho creds land.
# REMOVE once real credentials are populated — leaving this on weakens security.
# RELAX_PROD_VALIDATION=true

# ── Billing-cron kill-switch ──────────────────────────────────────────────────
# MUST NOT be set to true in production
THROTTLER_DISABLED=false

# ── Sentry (optional — leave blank until GlitchTip / Sentry Cloud is wired) ──
# SENTRY_DSN=

# ── Backup (VPS-level, used by scripts/backup-*.sh — not consumed by Joi) ────
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=

# ── Legacy subdomain tenant routing ──────────────────────────────────────────
# Not used for Sawa single-company mode. Preserve value only to avoid breaking
# env validation/deployment wiring that still expects the key.
PLATFORM_ROOT_DOMAIN=sawaa.net
# Optional CSV merged with the built-in reserved-subdomains list.
RESERVED_SUBDOMAINS=
