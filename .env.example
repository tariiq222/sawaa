# ═══════════════════════════════════════════════════════════
# Sawaa — Complete Environment Variables Reference
# Single-tenant mode (one company)
# ═══════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. BACKEND (apps/backend)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Core ──
NODE_ENV=development
PORT=5200
BACKEND_URL=http://localhost:5200
CORS_ORIGINS=

# ── Database ──
DATABASE_URL=postgresql://sawaa:sawaa_dev_password@localhost:3453/sawaa_dev?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Storage (MinIO) ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sawaa
MINIO_USE_SSL=false
BRANDING_ALLOWED_ASSET_HOSTS=localhost

# ── Auth (JWT) ──
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=30d
JWT_OTP_SECRET=dev-otp-secret-change-me
JWT_CLIENT_ACCESS_SECRET=dev-client-access-secret-change-me
JWT_CLIENT_ACCESS_TTL=15m
JWT_CLIENT_REFRESH_SECRET=dev-client-refresh-secret-change-me
JWT_CLIENT_REFRESH_TTL=30d

# ── Platform Identity (Saudi VAT/ZATCA) ──
PLATFORM_VAT_NUMBER=
PLATFORM_COMPANY_NAME_AR=
PLATFORM_COMPANY_NAME_EN=
PLATFORM_COMPANY_ADDRESS=

# ── Providers ──
# Moyasar
MOYASAR_PLATFORM_SECRET_KEY=
MOYASAR_PLATFORM_WEBHOOK_SECRET=
MOYASAR_PLATFORM_PUBLISHABLE_KEY=pk_test_...your_key_here
MOYASAR_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=

# Authentica (OTP)
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# Resend (email)
RESEND_API_KEY=re_...your_key_here
RESEND_FROM=Sawaa <noreply@mail.sawaa.app>
RESEND_REPLY_TO=support@sawaa.app

# SMS
SMS_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=
SMS_WEBHOOK_URL_BASE=

# Zoom
ZOOM_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=

# Email encryption
EMAIL_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=

# ── AI ──
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku

# ── Notifications ──
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Monitoring ──
SENTRY_DSN=
SENTRY_RELEASE=

# ── Dev flags ──
TENANT_ENFORCEMENT=off
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
THROTTLER_DISABLED=false
E2E_TEST=false
MOBILE_OTP_DEV_BYPASS_CODE=
MOBILE_OTP_FULL_BYPASS=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 2. DASHBOARD (apps/dashboard)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_API_URL=http://localhost:5200/api/v1
NEXT_PUBLIC_DEV_EMAIL=admin@sawa.local
NEXT_PUBLIC_DEV_PASSWORD=change-me
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=localhost
E2E_TEST=false
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=sawa-dashboard
SENTRY_URL=https://errors.webvue.pro/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3. WEBSITE (apps/website)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEXT_PUBLIC_API_URL=http://localhost:5200
NEXT_PUBLIC_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_HOST_ORG_MAP=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_WEBSITE_URL=https://sawa.sa
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=sawa-website
SENTRY_URL=https://errors.webvue.pro/

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 4. MOBILE (apps/mobile)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
# Preferred. EXPO_PUBLIC_TENANT_ID remains a deprecated fallback for old builds.
EXPO_PUBLIC_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
EXPO_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001
EXPO_PUBLIC_VERTICAL_SLUG=family-consulting
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://sawa.sa/privacy
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_URL=https://errors.webvue.pro/
