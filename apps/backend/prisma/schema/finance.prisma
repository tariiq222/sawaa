// Finance BC — invoices, payments, coupons, gift cards, refunds.
// Models added in Phase 7 (p7-t*). Finance BC number in kanban: p6 (column 7).

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  PARTIALLY_REFUNDED
  VOID
  REFUNDED
}

enum PaymentMethod {
  ONLINE_CARD
  BANK_TRANSFER
  CASH
  COUPON
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  COMPLETED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Invoice ─────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  branchId       String
  clientId       String
  employeeId     String
  bookingId      String        @unique
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmt    Decimal       @default(0) @db.Decimal(12, 2)
  vatRate        Decimal       @default(0.15) @db.Decimal(5, 4)
  vatAmt         Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  refundedAmount Decimal       @default(0) @db.Decimal(12, 2)
  refundedVatAmt Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("SAR")
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payments       Payment[]
  refundRequests RefundRequest[]

  @@index([clientId])
  @@index([bookingId])
  @@index([status, dueAt])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  invoiceId      String
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount         Decimal       @db.Decimal(12, 2)
  refundedAmount Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("SAR")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  gatewayRef     String?       @unique // Moyasar payment id
  idempotencyKey String?       @unique // prevent duplicate webhook processing
  receiptUrl     String? // MinIO path for bank transfer receipt
  failureReason  String?
  processedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  refundRequests RefundRequest[]

  @@index([invoiceId])
  @@index([gatewayRef])
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(uuid())
  code           String // uniqueness now composite-per-org
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  minOrderAmt    Decimal?     @db.Decimal(12, 2)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  descriptionAr  String?
  descriptionEn  String?
  maxUsesPerUser Int?
  serviceIds     String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  invoiceId  String
  clientId   String
  discount   Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())

  @@unique([couponId, invoiceId])
  @@index([invoiceId])
}

// ─── Refund Request ──────────────────────────────────────────────────────────────

enum RefundStatus {
  PENDING_REVIEW
  APPROVED
  DENIED
  PROCESSING
  COMPLETED
  FAILED
}

model RefundRequest {
  id           String       @id @default(uuid())
  invoiceId    String
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paymentId    String
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  clientId     String
  amount       Decimal      @db.Decimal(12, 2)
  reason       String?
  status       RefundStatus @default(PENDING_REVIEW)
  processedAt  DateTime?
  processedBy  String?
  denialReason String?
  gatewayRef   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([clientId])
  @@index([invoiceId])
  @@index([status])
}

// ─── Per-tenant Moyasar credentials (singleton per org) ──────────────────────
// Tenant uses their own Moyasar account to collect booking-payment revenue.
// Platform Moyasar (apps/backend/src/modules/platform/billing/) is a separate
// account that collects subscription fees from tenants. See memory
// `saas_moyasar_architecture` for the TWO-Moyasar design.

model OrganizationPaymentConfig {
  id                 String    @id @default(uuid())
  publishableKey     String // pk_test_… / pk_live_… — not secret, stored plain
  secretKeyEnc       String // AES-256-GCM ciphertext (base64)
  webhookSecretEnc   String // REQUIRED — AES-256-GCM, per-tenant webhook signing secret (2026-05-05)
  isLive             Boolean   @default(false)
  lastVerifiedAt     DateTime?
  lastVerifiedStatus String? // 'OK' | 'INVALID_KEY' | 'NETWORK_ERROR'
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
