// Finance BC — invoices, payments, coupons, gift cards, refunds.
// Models added in Phase 7 (p7-t*). Finance BC number in kanban: p6 (column 7).

// ─── Enums ───────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  PARTIALLY_REFUNDED
  VOID
  REFUNDED
}

enum PaymentMethod {
  ONLINE_CARD
  BANK_TRANSFER
  CASH
  COUPON
  MADA
  TABBY
}

enum PaymentStatus {
  PENDING
  PENDING_VERIFICATION
  COMPLETED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Invoice ─────────────────────────────────────────────────────────────────

// XOR constraint: exactly ONE of bookingId OR bundlePurchaseId must be non-null.
// Enforced in DB by migration 20260520150000_finalize_delivery_type_transition.
model Invoice {
  id               String        @id @default(uuid())
  number           Int           @unique @default(autoincrement())
  branchId         String
  clientId         String
  employeeId       String
  // DB-???: was non-null String. Made nullable to support bundle invoices.
  bookingId        String?
  // DB-???: links invoice to a bundle purchase. Nullable — XOR with bookingId.
  bundlePurchaseId String?
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  subtotal         Decimal       @db.Decimal(12, 2)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  discountAmt      Decimal       @default(0) @db.Decimal(12, 2)
  // Manual-discount audit trail. discountReasonId references DiscountReason
  // (no FK relation — cross-cluster id, kept as plain string per BC rules).
  discountReasonId String?
  discountAppliedBy String?
  discountAppliedAt DateTime?
  vatRate          Decimal       @default(0.15) @db.Decimal(5, 4)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  vatAmt           Decimal       @db.Decimal(12, 2)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  total            Decimal       @db.Decimal(12, 2)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  refundedAmount   Decimal       @default(0) @db.Decimal(12, 2)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  refundedVatAmt   Decimal       @default(0) @db.Decimal(12, 2)
  currency         String        @default("SAR")
  status           InvoiceStatus @default(DRAFT)
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  pdfUrl           String?
  pdfGeneratedAt   DateTime?
  sentToClientAt   DateTime?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  payments       Payment[]
  refundRequests RefundRequest[]

  @@unique([bookingId])
  @@unique([bundlePurchaseId])
  @@index([clientId])
  @@index([bookingId])
  @@index([bundlePurchaseId])
  @@index([status, dueAt])
  @@index([status, createdAt])
  @@index([employeeId])
}

// ─── Payment ──────────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  number         Int           @unique @default(autoincrement())
  invoiceId      String
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  amount         Decimal       @db.Decimal(12, 2)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  refundedAmount Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("SAR")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  gatewayRef     String?       @unique // Moyasar payment id
  idempotencyKey String?       @unique // prevent duplicate webhook processing
  receiptUrl     String? // MinIO path for bank transfer receipt
  failureReason  String?
  processedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  refundRequests RefundRequest[]

  @@index([invoiceId])
  @@index([gatewayRef])
  @@index([status, createdAt])
}

// ─── Coupon ───────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   DiscountType
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  discountValue  Decimal      @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  minOrderAmt    Decimal?     @db.Decimal(12, 2)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  descriptionAr  String?
  descriptionEn  String?
  maxUsesPerUser Int?
  serviceIds     String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  invoiceId  String
  clientId   String
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  discount   Decimal  @db.Decimal(12, 2)
  redeemedAt DateTime @default(now())

  @@unique([couponId, invoiceId])
  @@index([invoiceId])
}

// ─── Refund Request ──────────────────────────────────────────────────────────────

enum RefundStatus {
  PENDING_REVIEW
  APPROVED
  DENIED
  PROCESSING
  COMPLETED
  FAILED
}

model RefundRequest {
  id           String       @id @default(uuid())
  invoiceId    String
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  paymentId    String
  payment      Payment      @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  clientId     String
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  amount       Decimal      @db.Decimal(12, 2)
  reason       String?
  status       RefundStatus @default(PENDING_REVIEW)
  processedAt  DateTime?
  processedBy  String?
  denialReason String?
  gatewayRef   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([clientId])
  @@index([invoiceId])
  @@index([status])
  @@index([status, createdAt])
  @@index([paymentId])
}

// ─── Per-tenant Moyasar credentials (singleton per org) ──────────────────────
// Tenant uses their own Moyasar account to collect booking-payment revenue.
// Platform Moyasar (apps/backend/src/modules/platform/billing/) is a separate
// account that collects subscription fees from tenants. See memory
// `saas_moyasar_architecture` for the TWO-Moyasar design.

model OrganizationPaymentConfig {
  id                 String    @id @default(uuid())
  publishableKey     String // pk_test_… / pk_live_… — not secret, stored plain
  secretKeyEnc       String // AES-256-GCM ciphertext (base64)
  webhookSecretEnc   String // REQUIRED — AES-256-GCM, per-tenant webhook signing secret (2026-05-05)
  isLive             Boolean   @default(false)
  lastVerifiedAt     DateTime?
  lastVerifiedStatus String? // 'OK' | 'INVALID_KEY' | 'NETWORK_ERROR'
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
