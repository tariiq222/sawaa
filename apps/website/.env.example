# Server-side API origin. Set this in production to the internal backend
# service URL (e.g. http://sawaa-web-backend-xxxxx:5100) so SSR fetches
# stay inside the Docker network instead of routing through the public domain.
# Falls back to NEXT_PUBLIC_API_URL when unset (fine for local dev).
INTERNAL_API_URL=
NEXT_PUBLIC_API_URL=http://localhost:5200
NEXT_PUBLIC_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
# Legacy SaaS option. Leave empty for Sawa single-company mode.
# Optional: JSON map of hostname -> orgId
NEXT_PUBLIC_HOST_ORG_MAP=

# --- Sentry / GlitchTip error tracking ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=webvue
SENTRY_PROJECT=sawa-website
SENTRY_URL=https://errors.webvue.pro/
