// Ops BC — activity log, scheduled jobs, generated reports, health.
// Models added in Phase 10 (p10-t*).

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  SYSTEM
}

enum ReportType {
  REVENUE
  ACTIVITY
  BOOKINGS
  EMPLOYEES
  OVERVIEW
  CLIENTS
  SERVICES
  RATINGS
}

enum ReportFormat {
  JSON
  EXCEL
}

enum ReportStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── ActivityLog ─────────────────────────────────────────────────────────────
// SaaS-02g: scoped.

model ActivityLog {
  id          String         @id @default(uuid())
  userId      String?
  userEmail   String?
  action      ActivityAction
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  occurredAt  DateTime       @default(now())

  @@index([occurredAt])
  @@index([entity, entityId])
  @@index([userId])
}

// ─── CronHeartbeat ────────────────────────────────────────────────────────────
// Platform-level. One row per cron job name, updated after
// each successful run. Used by the watchdog cron to alert on missed heartbeats.

model CronHeartbeat {
  cronName  String   @id
  lastRunAt DateTime
  updatedAt DateTime @updatedAt
}

// ─── CronLock ─────────────────────────────────────────────────────────────────
// Platform-level distributed lease lock for single-leader cron execution. One
// row per cron job name. Replaces pg session advisory locks, which are unsafe
// over a connection pool (acquire/release can land on different connections, so
// the unlock silently fails and the lock leaks). Each acquire/release is a
// single atomic statement → pool-safe. A crashed leader's lease auto-expires
// after lockedUntil, so another instance can take over.

model CronLock {
  name        String   @id
  owner       String
  lockedUntil DateTime
  acquiredAt  DateTime @default(now())
}

// ─── Report ──────────────────────────────────────────────────────────────────
// SaaS-02g: scoped.

model Report {
  id          String       @id @default(uuid())
  type        ReportType
  format      ReportFormat @default(JSON)
  status      ReportStatus @default(PENDING)
  params      Json
  resultUrl   String?
  resultData  Json?
  errorMsg    String?
  requestedBy String?
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([type, createdAt])
}

// ─── OutboxEvent ──────────────────────────────────────────────────────────────
// CR-5: transactional outbox for reliable event delivery.
// Events are written here inside the booking (or any domain) transaction;
// OutboxPublisherCron picks them up every 5 s and forwards to EventBusService.
// publishedAt IS NULL means not yet published.

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateId   String
  eventType     String
  payload       Json
  status        String    @default("PENDING") // PENDING | PUBLISHED | FAILED
  lockedUntil   DateTime? @db.Timestamptz(3)
  publishedAt   DateTime? @db.Timestamptz(3)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  attemptCount  Int       @default(0)
  failedAt      DateTime? @db.Timestamptz(3)
  failureReason String?

  @@index([publishedAt], map: "OutboxEvent_publishedAt_idx")
  @@index([status, lockedUntil], map: "OutboxEvent_status_locked_idx")
  @@index([failedAt], map: "OutboxEvent_failedAt_idx")
}
