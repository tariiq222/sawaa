# Deqah Backend v2 environment
NODE_ENV=development
PORT=5100

# --- Sentry / GlitchTip error tracking ---
# Leave empty to silently disable (safe for local dev).
SENTRY_DSN=
SENTRY_RELEASE=

# CORS — allowed origins (comma-separated, no trailing slash).
# Leave empty in dev (defaults to localhost). MUST be set in production.
# Example: https://dashboard.yourclinic.com,https://app.yourclinic.com
CORS_ORIGINS=

# PostgreSQL — separate DB from v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deqah_v2?schema=public

# RLS GUC interceptor — flip to "true" after running the 20260509000000 migration on staging
RLS_GUC_INTERCEPTOR_ENABLED=false

# Redis (BullMQ + cache + token blacklist)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=          # required in production; leave empty for local dev without auth

# MinIO (object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=deqah-v2
MINIO_USE_SSL=false

# BRANDING — host allowlist for tenant-supplied logo/favicon/font URLs and url(...)
# references inside customCss. Comma-separated hostnames (no protocol). Subdomains
# of listed hosts are allowed. Defaults to MINIO_ENDPOINT when unset.
BRANDING_ALLOWED_ASSET_HOSTS=localhost
# Optional separate allowlist for fontUrl. Falls back to asset hosts.
# BRANDING_ALLOWED_FONT_HOSTS=

# JWT — dev placeholders (min 16 chars). Override for staging/prod.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP JWT — dedicated secret so a leaked OTP token cannot forge access tokens.
# Falls back to JWT_ACCESS_SECRET if unset (dev only — set this in prod).
JWT_OTP_SECRET=dev-otp-secret-change-me

# Client JWT — separate namespace for website clients (Phase 3)
JWT_CLIENT_ACCESS_SECRET=dev-client-access-secret-change-me
JWT_CLIENT_ACCESS_TTL=15m

# FCM (push notifications)
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OpenAI (AI BC — embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenRouter (AI BC — chat)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku

# Multi-tenancy — default as of SaaS-02h.
#   strict     — platform default. Any scoped query without CLS org throws.
#   permissive — fall back to DEFAULT_ORGANIZATION_ID. Dev-only escape hatch.
#   off        — no enforcement. Legacy single-tenant mode. NEVER in multi-tenant prod.
TENANT_ENFORCEMENT=strict
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

# SMS per-tenant (SaaS-02g-sms)
# REQUIRED. 32 raw bytes base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SMS_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=
ZOOM_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=
MOYASAR_TENANT_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=

# Zoho Invoice integration — shared OAuth client + per-tenant refresh tokens.
# https://api-console.zoho.com (create a "Server-based Applications" client).
# Required scopes: ZohoInvoice.fullaccess.all
# Redirect URI must EXACTLY match what is registered in the Zoho client config.
ZOHO_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=
ZOHO_OAUTH_CLIENT_ID=
ZOHO_OAUTH_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=http://localhost:5100/dashboard/integrations/zoho/callback
# SaaS→tenant invoicing in Deqah's OWN Zoho org. Leave blank to disable.
ZOHO_PLATFORM_ORGANIZATION_ID=
ZOHO_PLATFORM_REFRESH_TOKEN=
ZOHO_PLATFORM_DC=sa
ZOHO_PLATFORM_WEBHOOK_SECRET=

# Per-tenant SMTP credentials encryption (EmailCredentialsService).
# 32-byte key, base64-encoded.
EMAIL_PROVIDER_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64_ENCODED_PLACEHOLDER=

SMS_WEBHOOK_URL_BASE=

# Billing (SaaS-04) — PLATFORM Moyasar (NOT tenant Moyasar).
# Used ONLY by src/modules/platform/billing/ to charge clinics for their SaaS subscription.
# MUST use sk_test_* keys in dev/test. Never commit production keys.
MOYASAR_PLATFORM_SECRET_KEY=sk_test_change-me
MOYASAR_PLATFORM_WEBHOOK_SECRET=change-me-in-production
SAAS_TRIAL_DAYS=14
SAAS_GRACE_PERIOD_DAYS=2
BILLING_CRON_ENABLED=false
# Slug of the plan used for orgs without an active subscription (free/entry tier).
# Must match an existing Plan.slug row. Format: ^[A-Z][A-Z0-9_]{1,31}$.
PLATFORM_DEFAULT_PLAN_SLUG=BASIC

# Super-admin panel (SaaS-05b)
# ADMIN_HOSTS: comma-separated list of Host headers accepted by AdminHostGuard.
# In dev: Next.js admin app (localhost:5104) proxies to backend (:5100).
# The proxy sends Host: localhost:5100 — so BOTH hosts must be listed.
# In prod: add your admin subdomain (e.g. admin.deqah.app).
ADMIN_HOSTS=localhost:5104,localhost:5100
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password
DASHBOARD_PUBLIC_URL=http://localhost:5103
# Public origin of the backend (used to build webhook URLs for Zoho, etc.).
# Must be reachable from the internet — `localhost` won't work for incoming
# webhooks; use ngrok / cloudflared tunnel in dev. HTTPS required in prod.
API_PUBLIC_URL=http://localhost:5100

# --- Authentica (platform OTP — same key for every tenant) ---
# https://portal.authentica.sa/settings/apikeys/
# Distinct from OrganizationSmsConfig (per-tenant booking SMS via Unifonic/Taqnyat).
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1


# --- Resend (platform transactional emails) ---
# https://resend.com/api-keys
# If unset in development, emails are silently skipped (warn only).
# In production (NODE_ENV=production) the service throws on startup if missing.
RESEND_API_KEY=re_...your_key_here
RESEND_FROM=Deqah <noreply@mail.deqah.app>
RESEND_REPLY_TO=support@deqah.app
# Base URL used in email CTAs pointing to the tenant dashboard (no trailing slash).
PLATFORM_DASHBOARD_URL=http://localhost:5103


# --- Phase 7 — invoice PDF rendering ---
MINIO_INVOICE_BUCKET=deqah-invoices

# --- Throttling ---
# Set to 'true' to bypass rate limits globally (automated test suites, TestSprite).
THROTTLER_DISABLED=false

# --- E2E Test flag ---
# Set to true ONLY in CI E2E job. Refused in production (captcha.verifier throws
# if CAPTCHA_PROVIDER=noop and NODE_ENV=production regardless of this flag).
E2E_TEST=false

# --- Owner-only access (OwnerOnlyGuard) ---
# Comma-separated list of super-admin emails allowed to perform the most sensitive
# operations: refund, waive, grant-credit, change-plan, force-charge,
# cancel-scheduled, and any billing-settings update (Moyasar credentials).
# OwnerOnlyGuard fails closed: if this var is unset or empty, ALL requests to
# owner-only endpoints are rejected. Set to your own email(s) in production.
OWNER_EMAILS=

# --- Subdomain tenant routing ---
# Root domain used to derive tenant from Host header (e.g. sawa.<root> → tenant "sawa").
# Required in production. In dev defaults to "localhost" if unset.
PLATFORM_ROOT_DOMAIN=deqah.net

# Optional CSV merged with the built-in reserved-subdomains list. Example:
# RESERVED_SUBDOMAINS=ops,beta
RESERVED_SUBDOMAINS=

# --- Mobile OTP dev bypass (NEVER set in production) ---
# When set, accepts this code in any mobile OTP screen as a dev shortcut.
# Only honored when NODE_ENV !== 'production'. Leave empty/unset to disable.
MOBILE_OTP_DEV_BYPASS_CODE=
# When true AND NODE_ENV != production, verify-mobile-otp accepts any
# code/identifier without needing an OTP record + skips rate limit.
# Local QA/demo only — MUST be false (or unset) in production.
MOBILE_OTP_FULL_BYPASS=false

# --- Platform identity (Saudi VAT/ZATCA — required for PDF invoices) ---
# 15-digit Saudi VAT number. Leave empty in dev; required for invoice PDFs in prod.
PLATFORM_VAT_NUMBER=
PLATFORM_COMPANY_NAME_AR=
PLATFORM_COMPANY_NAME_EN=
PLATFORM_COMPANY_ADDRESS=

# --- PostHog error tracking (server-side) ---
# Leave empty to silently disable.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
