{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "${IOS_APP_ID}",
        "ascTeamId": "${IOS_TEAM_ID}"
      },
      "android": {
        "serviceAccountKeyPath": "${ANDROID_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "production"
      }
    }
  }
}
