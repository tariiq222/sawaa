// People BC — clients, employees, availability, onboarding.
// Models added in Phase 4 (p4-t*).

// Gender is redeclared here independently — no cross-BC Prisma relations.
// The generated enum name is `ClientGender` to avoid collision with `UserGender`.
enum ClientGender {
  MALE
  FEMALE
}

enum ClientSource {
  WALK_IN
  ONLINE
  REFERRAL
}

enum ClientAccountType {
  FULL
  WALK_IN
}

enum ClientBloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

model Client {
  id                String            @id @default(uuid())
  userId            String?
  // Legacy single-name field kept in sync with first/middle/last on write.
  // Downstream readers that still key off `name` keep working; new code reads the components.
  name              String
  firstName         String?
  middleName        String?
  lastName          String?
  // SECURITY (P1): uniqueness enforced via PARTIAL unique indexes
  // (`client_phone_unique_idx`, `client_email_unique_idx`) defined in the
  // 20260522030000_security_hardening_constraints migration. Prisma's `@unique`
  // would reject any NULL beyond the first row, but walk-in clients legitimately
  // lack contact info — the partial index covers only non-null, non-empty values.
  phone             String?
  email             String?
  emailVerified     DateTime?
  phoneVerified     DateTime?
  gender            ClientGender?
  dateOfBirth       DateTime?
  nationality       String?
  nationalId        String?
  emergencyName     String?
  emergencyPhone    String?
  bloodType         ClientBloodType?
  allergies         String?
  chronicConditions String?
  avatarUrl         String?
  notes             String?
  source            ClientSource      @default(WALK_IN)
  accountType       ClientAccountType @default(WALK_IN)
  claimedAt         DateTime?
  isActive          Boolean           @default(true)
  deletedAt         DateTime?
  tokenVersion      Int               @default(0)
  passwordHash      String?
  loginAttempts     Int               @default(0)
  lockoutUntil      DateTime?
  lastLoginAt       DateTime?
  preferredLocale   String?           @db.VarChar(8)
  pushEnabled       Boolean           @default(true)
  // PDPL: explicit consent capture (privacy policy acceptance). Nullable —
  // legacy/walk-in clients predate consent; set on registration/booking.
  consentedAt       DateTime?
  consentVersion    String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([deletedAt])
  @@index([phone])
}

enum EmployeeGender {
  MALE
  FEMALE
}

enum OnboardingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

// Cross-BC IDs (branchId, serviceId) are plain strings —
// no Prisma FK relations to Clinic BC. Referential integrity is event-driven.
model Employee {
  id               String           @id @default(uuid())
  userId           String?
  name             String
  nameEn           String?
  nameAr           String?
  title            String?
  specialty        String?
  specialtyAr      String?
  phone            String?
  email            String?          @unique
  gender           EmployeeGender?
  avatarUrl        String?
  bio              String?
  bioAr            String?
  education        String?
  educationAr      String?
  experience       Int?
  employmentType   EmploymentType   @default(FULL_TIME)
  onboardingStatus OnboardingStatus @default(PENDING)
  isActive         Boolean          @default(true)
  /// Commission rate for this employee (0.0000–1.0000). Default 1.0 = 100% to employee.
  /// Override per service via Service.commissionRateOverride.
  commissionRate   Decimal          @default(1.0) @db.Decimal(5, 4)
  slug             String?
  isPublic         Boolean          @default(false)
  publicBioAr      String?
  publicBioEn      String?
  publicImageUrl   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  branches     EmployeeBranch[]
  services     EmployeeService[]
  availability EmployeeAvailability[]
  exceptions   EmployeeAvailabilityException[]
  breaks       EmployeeBreak[]

  @@index([userId])
  @@index([isPublic, isActive, createdAt])
}

model EmployeeBranch {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId   String

  // NOTE: (employeeId, branchId) unique constraint already exists — no migration needed.
  @@unique([employeeId, branchId])
  @@index([employeeId])
}

model EmployeeService {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  serviceId     String
  isActive      Boolean  @default(true)
  bufferMinutes Int      @default(0)

  // NOTE: (employeeId, serviceId) unique constraint already exists — no migration needed.
  @@unique([employeeId, serviceId])
  @@index([employeeId])
}

// Multiple rows per (employeeId, dayOfWeek) represent split shifts
// (e.g. 09:00-13:00 then 16:00-21:00). The gap between shifts IS the break.
// A missing dayOfWeek row = weekly off day.
model EmployeeAvailability {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, dayOfWeek])
}

// Date-range exception — employee is off from startDate to endDate (inclusive).
// Single-day leave: startDate == endDate. Annual leave: multi-day range.
// endTime + isStartTimeOnly support partial-day leave (e.g. 2:00 PM to 5:00 PM).
model EmployeeAvailabilityException {
  id              String    @id @default(uuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate       DateTime  @db.Date
  endDate         DateTime  @db.Date
  endTime         DateTime? // nullable — null means end of day (23:59:59.999)
  isStartTimeOnly Boolean   @default(false) // when true, only startTime matters (full-day leave)
  reason          String?
  createdAt       DateTime  @default(now())

  @@index([employeeId, startDate, endDate])
}

model EmployeeBreak {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, dayOfWeek])
}

// Password history for Client — prevents password reuse within N previous passwords.
// Used for password reset/change flows to enforce history policy.
model PasswordHistory {
  id           String   @id @default(uuid())
  clientId     String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([clientId, createdAt])
}
