// Bookings BC — appointments, group sessions.
// Models added in Phase 8 (p8-t*). Cross-BC IDs (clientId, employeeId, serviceId, branchId)
// are plain strings — no Prisma FK relations. Referential integrity is event-driven.

enum BookingStatus {
  PENDING
  PENDING_GROUP_FILL
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  EXPIRED
  CANCEL_REQUESTED
  DEPOSIT_PAID
}

enum BookingType {
  INDIVIDUAL
  WALK_IN
  GROUP
}

// DB-???: Delivery channel — independent from BookingType.
// IN_PERSON = physically at the branch; ONLINE = virtual (Zoom or other).
// ONLINE does NOT always require Zoom.
enum DeliveryType {
  IN_PERSON
  ONLINE
}

// Origin of the booking — where/how it was created.
// RECEPTION = created by staff at the front desk (dashboard/mobile-employee).
// ONLINE    = self-service booking from the public website.
// Existing rows backfill to RECEPTION (the @default).
enum BookingSource {
  RECEPTION
  ONLINE
}

enum CancellationReason {
  CLIENT_REQUESTED
  EMPLOYEE_UNAVAILABLE
  NO_SHOW
  SYSTEM_EXPIRED
  OTHER
}

enum ZoomMeetingStatus {
  PENDING
  CREATED
  FAILED
  CANCELLED
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id                   String              @id @default(uuid())
  branchId             String
  clientId             String
  employeeId           String
  serviceId            String
  bookingType          BookingType         @default(INDIVIDUAL)
  // DB-???: deliveryType — required delivery channel; bookingType now models appointment shape only.
  deliveryType         DeliveryType
  // Origin of the booking (front desk vs public website). Existing rows backfill to RECEPTION.
  source               BookingSource       @default(RECEPTION)
  status               BookingStatus       @default(PENDING)
  scheduledAt          DateTime
  endsAt               DateTime // scheduledAt + durationMins — stored for overlap index queries
  durationMins         Int
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  price                Decimal             @db.Decimal(12, 2)
  currency             String              @default("SAR")
  notes                String?
  cancelReason         CancellationReason?
  cancelNotes          String?
  cancelledAt          DateTime?
  confirmedAt          DateTime?
  checkedInAt          DateTime?
  completedAt          DateTime?
  noShowAt             DateTime?
  expiresAt            DateTime?
  durationOptionId     String? // cross-BC ref to ServiceDurationOption — plain string, no FK
  groupSessionId       String?
  groupSession         GroupSession?       @relation(fields: [groupSessionId], references: [id], onDelete: SetNull)
  bundleId             String?
  bundleGroupId        String?
  payAtClinic          Boolean             @default(false)
  couponCode           String?
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  discountedPrice      Decimal?            @db.Decimal(12, 2)
  zoomMeetingId        String?
  zoomJoinUrl          String?
  zoomHostUrl          String?
  zoomStartUrl         String?
  zoomMeetingStatus    ZoomMeetingStatus?
  zoomMeetingError     String?
  zoomMeetingCreatedAt DateTime?

  // ─── Snapshot fields (denormalized at booking creation for stable history) ───
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  priceSnapshot           Decimal? @db.Decimal(12, 2)
  durationMinutesSnapshot Int?
  branchNameSnapshot      String?
  employeeNameSnapshot    String?
  serviceNameSnapshot     String?
  categoryNameSnapshot    String?
  departmentNameSnapshot  String?

  // SECURITY (P1): uniqueness on bookingNumber is enforced by the partial
  // unique index `booking_bookingnumber_unique_idx` in the
  // 20260522030000_security_hardening_constraints migration.
  bookingNumber Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  groupEnrollment GroupEnrollment?

  // DB-07: @@index([employeeId]) dropped — redundant prefix of [employeeId, scheduledAt] and [employeeId, endsAt]
  @@index([clientId])
  @@index([scheduledAt])
  @@index([status])
  @@index([employeeId, scheduledAt])
  @@index([employeeId, endsAt])
  @@index([employeeId, status, scheduledAt])
  @@index([employeeId, status, endsAt])
  @@index([branchId, scheduledAt])
  @@index([serviceId, scheduledAt])
  @@index([bundleGroupId])
}

// ─── Group Session ────────────────────────────────────────────────────────────

enum GroupSessionStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

model GroupSession {
  id                  String             @id @default(uuid())
  branchId            String
  employeeId          String
  serviceId           String
  title               String
  descriptionAr       String?
  descriptionEn       String?
  scheduledAt         DateTime
  durationMins        Int
  maxCapacity         Int
  enrolledCount       Int                @default(0)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  price               Decimal            @db.Decimal(12, 2)
  currency            String             @default("SAR")
  status              GroupSessionStatus @default(OPEN)
  // DB-???: deliveryType — supports both IN_PERSON and ONLINE group sessions.
  deliveryType        DeliveryType
  isPublic            Boolean            @default(false)
  publicDescriptionAr String?
  publicDescriptionEn String?
  cancelReason        String?
  cancelledAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  enrollments     GroupEnrollment[]
  bookings        Booking[]

  @@index([employeeId])
  @@index([scheduledAt])
  @@index([isPublic])
}

model GroupEnrollment {
  id             String       @id @default(uuid())
  groupSessionId String
  groupSession   GroupSession @relation(fields: [groupSessionId], references: [id], onDelete: Cascade)
  clientId       String
  bookingId      String       @unique
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  enrolledAt     DateTime     @default(now())

  @@unique([groupSessionId, clientId])
  @@index([clientId])
}

// ─── BookingStatusLog ─────────────────────────────────────────────────────────

model BookingStatusLog {
  id         String         @id @default(uuid())
  bookingId  String
  fromStatus BookingStatus?
  toStatus   BookingStatus
  changedBy  String
  reason     String?
  createdAt  DateTime       @default(now())

  @@index([bookingId])
  @@index([createdAt])
}

// ─── BookingSettings ──────────────────────────────────────────────────────────

enum RefundType {
  FULL
  PARTIAL
  NONE
}

model BookingSettings {
  id       String  @id @default(uuid())
  branchId String? // null = global default; one settings row per branch

  bufferMinutes           Int        @default(0)
  freeCancelBeforeHours   Int        @default(24)
  freeCancelRefundType    RefundType @default(FULL)
  lateCancelRefundPercent Int        @default(0)

  maxReschedulesPerBooking Int @default(3)

  autoCompleteAfterHours Int @default(2)
  autoNoShowAfterMinutes Int @default(30)

  minBookingLeadMinutes Int @default(60)
  maxAdvanceBookingDays Int @default(90)

  payAtClinicEnabled    Boolean @default(false)
  requireCancelApproval Boolean @default(false)
  autoRefundOnCancel    Boolean @default(true)

  clientRescheduleMinHoursBefore Int @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Bundle Purchase ─────────────────────────────────────────────────────────

enum BundlePurchaseStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

model BundlePurchase {
  id            String               @id @default(uuid())
  bundleId      String
  clientId      String
  branchId      String
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  amountPaid    Decimal              @db.Decimal(12, 2)
  paidAt        DateTime
  expiresAt     DateTime?
  status        BundlePurchaseStatus @default(ACTIVE)
  notes         String?
  /// Total number of sessions included in the bundle.
  quantityTotal Int                  @default(0)
  /// Number of sessions already consumed.
  quantityUsed  Int                  @default(0)
  createdAt     DateTime             @default(now())

  usages BundleUsage[]

  @@index([clientId])
  @@index([bundleId])
  @@index([status])
}

model BundleUsage {
  id           String         @id @default(uuid())
  purchaseId   String
  purchase     BundlePurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  bookingId    String? // cross-BC ref to Booking — plain string, no FK
  serviceId    String
  deliveryType DeliveryType
  quantityUsed Int            @default(1)
  usedAt       DateTime       @default(now())
  notes        String?
  createdAt    DateTime       @default(now())

  @@index([purchaseId])
  @@index([bookingId])
  @@index([serviceId])
}
