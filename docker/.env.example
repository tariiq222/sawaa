# Sawa single-company dev stack — copy to docker/.env and tweak as needed.
# docker compose -f docker/docker-compose.yml --env-file docker/.env up
#
# Every value below is a DEV PLACEHOLDER. Production deployments must
# override these via secret manager / orchestrator-injected env, not
# this file.

# ── Auth (rotate per environment) ─────────────────────────────────────
JWT_ACCESS_SECRET=dev-jwt-access-secret-change-me-32c
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me-32c
JWT_CLIENT_ACCESS_SECRET=dev-client-access-secret-change-32c
JWT_CLIENT_REFRESH_SECRET=dev-client-refresh-secret-change-32c

# ── Encryption keys (must be 32 bytes / base64) ───────────────────────
EMAIL_PROVIDER_ENCRYPTION_KEY=ZGV2LWVtYWlsLWVuY3J5cHRpb24ta2V5LWNoYW5nZSE=
SMS_PROVIDER_ENCRYPTION_KEY=ZGV2LXNtcy1lbmNyeXB0aW9uLWtleS1jaGFuZ2VtZSE=
ZOOM_PROVIDER_ENCRYPTION_KEY=ZGV2LXpvb20tZW5jcnlwdGlvbi1rZXktY2hhbmdlbWU=
MOYASAR_TENANT_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAP8=

# ── External providers (replace with real keys in any deployed env) ──
AUTHENTICA_API_KEY=dev-authentica-key-placeholder
OPENAI_API_KEY=dev-openai-key-placeholder
OPENROUTER_API_KEY=dev-openrouter-key-placeholder
MOYASAR_PLATFORM_SECRET_KEY=dev-moyasar-platform-secret
MOYASAR_PLATFORM_WEBHOOK_SECRET=dev-moyasar-platform-webhook

# ── Sawa identity (Saudi VAT — replace with Sawa production values) ──────────
PLATFORM_VAT_NUMBER=300000000000003
PLATFORM_COMPANY_NAME_AR=مركز سواء للاستشارات الأسرية
PLATFORM_COMPANY_NAME_EN=Sawa Family Counseling Center
PLATFORM_COMPANY_ADDRESS=Riyadh, Saudi Arabia

# ── Single-company routing ─────────────────────────────────────────────
# SaaS admin app / tenant routing / license-server values are legacy Deqah
# leftovers. Keep enforcement off and use one fixed organization id locally.
ADMIN_HOSTS=localhost:5100
LICENSE_SERVER_URL=
TENANT_ENFORCEMENT=off
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
PLATFORM_ROOT_DOMAIN=localhost
RESERVED_SUBDOMAINS=
