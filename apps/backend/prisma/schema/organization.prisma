// Organization BC — branches, services, business-hours, holidays,
// branding-config, intake-forms, ratings. Phase 5 (p5-t*).

// ─── Branches ────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  nameAr    String
  nameEn    String?
  phone     String?
  addressAr String?
  addressEn String?
  city      String?
  country   String   @default("SA")
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  isMain    Boolean  @default(false)
  timezone  String   @default("Asia/Riyadh")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessHours BusinessHour[]
  holidays      Holiday[]
}

// ─── Departments ─────────────────────────────────────────────────────────────

// isVisible = false → يُخفى القسم في الواجهة وتُعرض فئاته مباشرة تحت الجذر.
model Department {
  id            String   @id @default(uuid())
  nameAr        String   @unique // was @unique globally
  nameEn        String?
  descriptionAr String?
  descriptionEn String?
  icon          String?
  isVisible     Boolean  @default(true)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categories ServiceCategory[]

  @@index([isActive])
}

// ─── Service Categories ──────────────────────────────────────────────────────

// departmentId nullable لدعم فئات بلا قسم (hierarchy مسطح).
model ServiceCategory {
  id           String      @id @default(uuid())
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  nameAr       String
  nameEn       String?
  sortOrder    Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  services Service[]

  @@index([isActive])
  @@index([departmentId])
}

// ─── Services ────────────────────────────────────────────────────────────────

enum RecurringPattern {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Service {
  id            String           @id @default(uuid())
  categoryId    String?
  category      ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  nameAr        String
  nameEn        String?
  descriptionAr String?
  descriptionEn String?
  durationMins  Int
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  price         Decimal          @db.Decimal(12, 2)
  currency      String           @default("SAR")
  imageUrl      String?
  isActive      Boolean          @default(true)
  archivedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // ─── العرض/الإخفاء ───────────────────────────────────────────────────────
  isHidden              Boolean @default(false)
  hidePriceOnBooking    Boolean @default(false)
  hideDurationOnBooking Boolean @default(false)

  // ─── الهوية البصرية ───────────────────────────────────────────────────────
  // iconName = Lucide icon name (string, not enum — icon list changes with library versions)
  iconName    String?
  iconBgColor String?

  // ─── قواعد الجدولة ───────────────────────────────────────────────────────
  bufferMinutes  Int  @default(0)
  minLeadMinutes Int?
  maxAdvanceDays Int?

  // ─── العربون ─────────────────────────────────────────────────────────────
  // depositAmount must not exceed price — enforced by CHECK constraint
  // "service_deposit_not_exceeding_price" (migration 20260605120100).
  depositEnabled Boolean  @default(false)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  depositAmount  Decimal? @db.Decimal(12, 2)

  // ─── Commission override ────────────────────────────────────────────────
  /// Per-service commission rate override (0.0000–1.0000). Null → use Employee.commissionRate.
  commissionRateOverride Decimal? @db.Decimal(5, 4)

  // ─── Participants (group sessions) ───────────────────────────────────────
  // minParticipants <= maxParticipants — enforced by CHECK constraint
  // "service_min_le_max_participants" (migration 20260605120100).
  minParticipants Int @default(1)
  maxParticipants Int @default(1)

  // ─── التكرار ─────────────────────────────────────────────────────────────
  allowRecurring           Boolean            @default(false)
  allowedRecurringPatterns RecurringPattern[] @default([])
  maxRecurrences           Int?

  // ─── الجلسات الجماعية ────────────────────────────────────────────────────
  // reserveWithoutPayment: payment deferred until minParticipants is reached (24h window)
  reserveWithoutPayment Boolean @default(false)

  durationOptions     ServiceDurationOption[]
  bookingConfigs      ServiceBookingConfig[]
  availabilityWindows ServiceAvailabilityWindow[]
  bundleItems         ServiceBundleItem[]

  @@index([isActive])
  @@index([isHidden])
  @@index([categoryId])
}

// ─── Service Booking Config ──────────────────────────────────────────────────

// Per-service delivery channel configuration (IN_PERSON / ONLINE).
// Each (serviceId, deliveryType) pair is unique.
model ServiceBookingConfig {
  id                    String       @id @default(uuid())
  serviceId             String
  service               Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  deliveryType          DeliveryType
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  price                 Decimal      @default(0) @db.Decimal(12, 2)
  durationMins          Int          @default(30)
  isActive              Boolean      @default(true)
  useCustomAvailability Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([serviceId, deliveryType])
  @@index([serviceId])
}

// ─── Service Availability Windows ───────────────────────────────────────────

// Optional per-service weekly windows scoped by delivery channel.
// Empty or disabled custom availability means the service inherits branch hours.
model ServiceAvailabilityWindow {
  id           String       @id @default(uuid())
  serviceId    String
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  deliveryType DeliveryType
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([serviceId])
  @@index([serviceId, deliveryType, dayOfWeek])
}

// ─── Service Duration Options ────────────────────────────────────────────────

// Per-service duration/price variants scoped by delivery channel.
// Multiple duration rows may exist for the same (serviceId, deliveryType),
// so this model intentionally has an index, not a unique constraint.
model ServiceDurationOption {
  id           String       @id @default(uuid())
  serviceId    String
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  deliveryType DeliveryType
  label        String
  labelAr      String
  durationMins Int
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  price        Decimal      @db.Decimal(12, 2)
  currency     String       @default("SAR")
  isDefault    Boolean      @default(false)
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  employeeOptions EmployeeServiceOption[]

  @@index([serviceId])
  @@index([serviceId, deliveryType])
}

// ─── Employee Service Options ────────────────────────────────────────────────

// Per-employee override of a specific ServiceDurationOption.
// employeeServiceId is a plain string (cross-BC to people.EmployeeService —
// no Prisma FK, referential integrity is event-driven).
// priceOverride / durationOverride = null → fall back to ServiceDurationOption values.
// Resolution order (PriceResolverService): (1) priceOverride → (2) ServiceDurationOption.price → (3) Service.price
model EmployeeServiceOption {
  id                String                @id @default(uuid())
  employeeServiceId String // FK to people.EmployeeService (plain string, cross-BC)
  durationOptionId  String
  durationOption    ServiceDurationOption @relation(fields: [durationOptionId], references: [id], onDelete: Cascade)
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  priceOverride     Decimal?              @db.Decimal(12, 2)
  durationOverride  Int?
  // DB-???: deliveryType — copied from linked ServiceDurationOption.deliveryType.
  deliveryType      DeliveryType
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([employeeServiceId, durationOptionId, deliveryType], map: "EmployeeServiceOption_employee_duration_delivery_key")
  @@index([employeeServiceId])
  @@index([durationOptionId])
}

// ─── Business Hours ──────────────────────────────────────────────────────────

// dayOfWeek: 0=Sunday … 6=Saturday
model BusinessHour {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  startTime String // "HH:mm"
  endTime   String // "HH:mm"
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, dayOfWeek])
  @@index([branchId])
}

// ─── Holidays ────────────────────────────────────────────────────────────────

model Holiday {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  nameAr    String
  nameEn    String?
  createdAt DateTime @default(now())

  @@unique([branchId, date])
  @@index([branchId])
}

// ─── Intake Forms ─────────────────────────────────────────────────────────────

enum IntakeFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  SELECT
  CHECKBOX
  RADIO
}

enum IntakeFormType {
  PRE_BOOKING
  PRE_SESSION
  POST_SESSION
  REGISTRATION
}

enum IntakeFormScope {
  GLOBAL
  SERVICE
  EMPLOYEE
  BRANCH
}

model IntakeForm {
  id        String          @id @default(uuid())
  nameAr    String
  nameEn    String?
  type      IntakeFormType  @default(PRE_SESSION)
  scope     IntakeFormScope @default(GLOBAL)
  scopeId   String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  fields    IntakeField[]
  responses IntakeResponse[]
}

model IntakeField {
  id         String          @id @default(uuid())
  formId     String
  form       IntakeForm      @relation(fields: [formId], references: [id], onDelete: Cascade)
  labelAr    String
  labelEn    String?
  fieldType  IntakeFieldType
  isRequired Boolean         @default(false)
  options    Json? // string[] for SELECT/RADIO/CHECKBOX
  position   Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([formId])
}

model IntakeResponse {
  id        String     @id @default(uuid())
  formId    String
  form      IntakeForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  bookingId String
  clientId  String?
  answers   Json // Record<fieldId, string | string[]>
  createdAt DateTime   @default(now())

  @@index([bookingId])
  @@index([formId])
}

// ─── Ratings ──────────────────────────────────────────────────────────────────

model Rating {
  id         String   @id @default(uuid())
  bookingId  String   @unique // one rating per booking
  clientId   String
  employeeId String
  score      Int // 1–5
  comment    String?
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@index([clientId])
  @@index([employeeId, createdAt])
  @@index([clientId, createdAt])
}

// ─── Organization Settings ────────────────────────────────────────────────────

model OrganizationSettings {
  id                     String    @id @default(uuid()) // SaaS-02c: was @default("default")
  companyNameAr          String?
  companyNameEn          String?
  productTagline         String?
  businessRegistration   String?
  vatRegistrationNumber  String?
  vatRate                Decimal   @default(0.15) @db.Decimal(5, 4)
  sellerAddress          String?
  organizationCity       String    @default("Riyadh")
  postalCode             String?
  contactPhone           String?
  contactEmail           String?
  address                String?
  socialMedia            Json?
  aboutAr                String?
  aboutEn                String?
  privacyPolicyAr        String?
  privacyPolicyEn        String?
  termsAr                String?
  termsEn                String?
  cancellationPolicyAr   String?
  cancellationPolicyEn   String?
  defaultLanguage        String    @default("ar")
  timezone               String    @default("Asia/Riyadh")
  weekStartDay           String    @default("sunday")
  dateFormat             String    @default("DD/MM/YYYY")
  timeFormat             String    @default("12h")
  emailHeaderShowLogo    Boolean   @default(true)
  emailHeaderShowName    Boolean   @default(true)
  emailFooterPhone       String?
  emailFooterWebsite     String?
  emailFooterInstagram   String?
  emailFooterTwitter     String?
  emailFooterSnapchat    String?
  emailFooterTiktok      String?
  emailFooterLinkedin    String?
  emailFooterYoutube     String?
  sessionDuration        Int       @default(60)
  reminderBeforeMinutes  Int       @default(60)
  bookingFlowOrder       String    @default("service_first")
  paymentMoyasarEnabled  Boolean   @default(true)
  paymentAtClinicEnabled Boolean   @default(false)
  // Manual payment-recording methods shown in the bookings "record payment"
  // dialog. Cash is on by default; the rest are opt-in from settings.
  payMethodCashEnabled   Boolean   @default(true)
  payMethodBankEnabled   Boolean   @default(true)
  payMethodMadaEnabled   Boolean   @default(false)
  payMethodTabbyEnabled  Boolean   @default(false)
  customDomainGraceUntil DateTime? // set when CUSTOM_DOMAIN is revoked on downgrade; tenant keeps access until this date
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// ─── Service Bundles ─────────────────────────────────────────────────────────

// الباقة = مجموعة خدمات بسعر موحّد عبر خصم على مجموع الأسعار.
// السعر النهائي محسوب وقت العرض/الحجز — لا يُخزّن (يبقى متّسقاً مع تغيّر أسعار الخدمات).
// discountValue >= 0 — enforced via CHECK constraint in migration SQL
model ServiceBundle {
  id            String       @id @default(uuid())
  nameAr        String
  nameEn        String?
  descriptionAr String?
  descriptionEn String?
  imageUrl      String?
  iconName      String?
  iconBgColor   String?
  discountType  DiscountType
  /// Stored in integer halalas (1 SAR = 100). See packages/shared/money.
  discountValue Decimal      @db.Decimal(12, 2)
  currency      String       @default("SAR")
  isActive      Boolean      @default(true)
  isHidden      Boolean      @default(false)
  sortOrder     Int          @default(0)
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  items ServiceBundleItem[]

  @@index([isActive])
  @@index([isHidden])
}

// جدول الربط bundle ↔ services. sortOrder يحدد ترتيب تنفيذ الحجوزات المتتالية.
model ServiceBundleItem {
  id        String        @id @default(uuid())
  bundleId  String
  bundle    ServiceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())

  @@unique([bundleId, serviceId])
  @@index([bundleId])
  @@index([serviceId])
}

// ─── Discount Reasons ──────────────────────────────────────────────────────────
// Admin-managed reasons for manual invoice discounts (e.g. "خصم من المعالج",
// "خصم خاص", "خصم من سواء"). Referenced by Invoice.discountReasonId.
model DiscountReason {
  id        String   @id @default(uuid())
  labelAr   String
  labelEn   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}
