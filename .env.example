# Sawa Family Counseling — Single-Tenant .env.example
# Derived from Sawaa SaaS, stripped of multi-tenant configuration.

# --- Core Runtime ---
NODE_ENV=development
PORT=5100
API_PUBLIC_URL=http://localhost:5100
BACKEND_URL=http://localhost:5100
DASHBOARD_PUBLIC_URL=http://localhost:5103
DASHBOARD_URL=http://localhost:5103
PUBLIC_WEBSITE_URL=http://localhost:5105
WEBSITE_URL=http://localhost:5105
CORS_ORIGINS=http://localhost:5103,http://localhost:5105

# --- Database (Prisma + Postgres) ---
DATABASE_URL=postgresql://deqah:deqah_dev_password@localhost:3453/deqah_dev?schema=public
APP_DB_USER=deqah_app
APP_DB_PASSWORD=dev-app-db-password-change-me
DB_STATEMENT_TIMEOUT_MS=30000
DB_POOL_TIMEOUT_S=20
DB_CONNECTION_LIMIT=10

# --- Redis (BullMQ + cache) ---
REDIS_HOST=localhost
REDIS_PORT=3454
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=3455
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=sawa
MINIO_USE_SSL=false
MINIO_INVOICE_BUCKET=sawa-invoices

# --- JWT (Identity BC) ---
JWT_ACCESS_SECRET=dev-jwt-access-secret-change-me-32c
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me-32c
JWT_REFRESH_TTL=30d
JWT_OTP_SECRET=dev-jwt-otp-secret-change-me-32c
JWT_CLIENT_ACCESS_SECRET=dev-jwt-client-access-secret-change-32c
JWT_CLIENT_ACCESS_TTL=15m
JWT_CLIENT_REFRESH_TTL=7d

# --- Encryption keys ---
SMS_PROVIDER_ENCRYPTION_KEY=ZGV2LXNtcy1lbmNyeXB0aW9uLWtleS1jaGFuZ2VtZSE=
ZOOM_PROVIDER_ENCRYPTION_KEY=ZGV2LXpvb20tZW5jcnlwdGlvbi1rZXktY2hhbmdlbWU=
MOYASAR_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAP8=
EMAIL_PROVIDER_ENCRYPTION_KEY=ZGV2LWVtYWlsLWVuY3J5cHRpb24ta2V5LWNoYW5nZSE=

# --- Auth bootstrap ---
# Admin password for seed script. Min 16 chars.
ADMIN_PASSWORD=Admin@1234
PASSWORD_RESET_BASE_URL=http://localhost:3451

# --- Authentica (OTP provider) ---
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_DEFAULT_TEMPLATE_ID=1

# --- Email (Resend + SMTP fallback) ---
RESEND_API_KEY=
RESEND_FROM="Sawa <noreply@sawa.sa>"
RESEND_REPLY_TO=support@sawa.sa
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Push notifications (FCM) ---
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# --- AI (embeddings + chat) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=anthropic/claude-3.5-haiku

# --- Sentry / observability ---
SENTRY_DSN=
SENTRY_RELEASE=

# --- SMS webhook ---
SMS_WEBHOOK_URL_BASE=

# --- Branding ---
BRANDING_ALLOWED_ASSET_HOSTS=localhost

# --- Internal metrics endpoint ---
INTERNAL_METRICS_TOKEN=
INTERNAL_METRICS_ALLOWED_IPS=127.0.0.1,::1

# --- Feature flags ---
COUPON_STRICT_ENABLED=false
BOOKING_EXPIRY_CRON_ENABLED=false

# --- Test / dev only ---
E2E_TEST=false
THROTTLER_DISABLED=false
WRITE_OPENAPI_SPEC=false
RELAX_PROD_VALIDATION=false
