// Comms BC — notifications, chat, email templates.
// Phase 9 (p9-t*).

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_COMPLETED
  PAYMENT_REMINDER
  WELCOME
  GENERAL
}

enum RecipientType {
  CLIENT
  EMPLOYEE
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageSenderType {
  CLIENT
  EMPLOYEE
  AI
}

model Notification {
  id            String           @id @default(uuid())
  recipientId   String
  recipientType RecipientType
  type          NotificationType
  title         String
  body          String
  metadata      Json?
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([recipientId])
  @@index([recipientId, isRead, createdAt]) // DB-06: replaces (recipientId, createdAt) — adds isRead to avoid heap filter
}

model ChatConversation {
  id            String             @id @default(uuid())
  clientId      String
  employeeId    String?
  isAiChat      Boolean            @default(false)
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  messages CommsChatMessage[]

  @@index([clientId])
  @@index([employeeId])
  @@index([status, lastMessageAt])
}

model CommsChatMessage {
  id             String            @id @default(uuid())
  conversationId String
  conversation   ChatConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     MessageSenderType
  senderId       String?
  body           String
  isRead         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactMessage {
  id         String               @id @default(uuid())
  name       String
  phone      String?
  email      String?
  subject    String?
  body       String
  status     ContactMessageStatus @default(NEW)
  createdAt  DateTime             @default(now())
  readAt     DateTime?
  archivedAt DateTime?

  @@index([status, createdAt])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  slug      String
  name      String
  subject   String
  htmlBody  String
  blocks    Json? // SaaS — block-builder source of truth; htmlBody is rendered from this
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// SaaS-02g-sms — per-tenant SMS provider configuration.

enum SmsProvider {
  NONE
  UNIFONIC
  TAQNYAT
}

enum SmsDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNKNOWN
}

model OrganizationSmsConfig {
  id                    String      @id @default(uuid())
  provider              SmsProvider @default(NONE)
  senderId              String? // e.g. "Deqah" or per-tenant brand
  // Encrypted credential payload (AES-GCM). JSON-stringified provider-specific fields.
  credentialsCiphertext String? // base64(nonce || tag || ciphertext)
  webhookSecret         String? // HMAC secret for DLR signature
  lastTestAt            DateTime?
  lastTestOk            Boolean?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model SmsDelivery {
  id                String            @id @default(uuid())
  provider          SmsProvider
  toPhone           String
  body              String
  bodyHash          String // sha256, used for idempotency with retries
  status            SmsDeliveryStatus @default(QUEUED)
  providerMessageId String?           @unique
  errorCode         String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status, createdAt]) // DB-06: replaces (status) + (createdAt) — composite for retry sweep
}

// SaaS-email-provider — per-tenant email provider configuration.

enum EmailProvider {
  NONE
  SMTP
  RESEND
  SENDGRID
  MAILCHIMP
}

model OrganizationEmailConfig {
  id                    String        @id @default(uuid())
  provider              EmailProvider @default(NONE)
  senderName            String? // e.g. "عيادة الأمل"
  senderEmail           String? // e.g. "noreply@clinic.com"
  // Encrypted credential payload (AES-GCM). JSON-stringified provider-specific fields.
  credentialsCiphertext String? // base64(nonce || tag || ciphertext)
  lastTestAt            DateTime?
  lastTestOk            Boolean?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model FcmToken {
  id         String   @id @default(uuid())
  clientId   String
  token      String
  platform   String   @db.VarChar(8)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([clientId, token], name: "fcm_token_per_client")
  @@index([clientId])
}

// Notification delivery log — resilient multi-channel dispatch tracking.

enum DeliveryChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NotificationPriority {
  CRITICAL
  STANDARD
}

enum NotificationSenderActor {
  PLATFORM
  TENANT
  PLATFORM_FALLBACK
}

model NotificationDeliveryLog {
  id            String                  @id @default(uuid())
  recipientId   String
  type          NotificationType
  priority      NotificationPriority    @default(STANDARD)
  channel       DeliveryChannel
  status        DeliveryStatus          @default(PENDING)
  toAddress     String?
  providerName  String?
  senderActor   NotificationSenderActor @default(TENANT)
  attempts      Int                     @default(0)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  errorMessage  String?
  jobId         String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([status])
  @@index([type])
  @@index([status, createdAt]) // DB-06: composite for retry sweep — replaces standalone (createdAt)
}
