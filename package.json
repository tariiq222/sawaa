{
  "name": "sawa-family-counseling",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "prepare": "lefthook install || true",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:dashboard": "turbo run dev --filter=dashboard -- --port 5203",
    "dev:website": "turbo run dev --filter=@sawaa/website -- --port 5205",
    "dev:all": "turbo run dev --filter=backend --filter=dashboard --filter=@sawaa/website",
    "build": "turbo run build --filter=backend --filter=dashboard --filter=@sawaa/website",
    "lint": "turbo run lint && node scripts/check-legacy-multitenant.js",
    "check:legacy-multitenant": "node scripts/check-legacy-multitenant.js",
    "check:api-client-drift": "node scripts/check-api-client-drift.mjs",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "typecheck": "turbo run typecheck",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file docker/.env up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file docker/.env down",
    "db:migrate": "pnpm --filter=backend run prisma:migrate:deploy",
    "db:seed": "pnpm --filter=backend run seed",
    "db:reset": "pnpm --filter=backend run prisma:migrate:deploy && pnpm --filter=backend run seed",
    "openapi:sync": "pnpm --filter=backend run openapi:export && pnpm --filter=dashboard run openapi:generate",
    "e2e:dashboard": "pnpm --filter dashboard e2e"
  },
  "devDependencies": {
    "lefthook": "^2.1.9",
    "react-test-renderer": "19.2.4",
    "turbo": "^2"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "react-test-renderer": "19.2.4",
      "@types/react": "18.3.28",
      "@types/react-dom": "18.3.7",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "fast-uri@<3.1.2": ">=3.1.2",
      "tmp@<0.2.6": ">=0.2.6"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "esbuild",
      "sharp",
      "bcrypt",
      "@swc/core",
      "@biomejs/biome"
    ]
  }
}
