{
  "name": "dashboard",
  "version": "0.6.1",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5103",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:report": "py ../../data/test-reports/scripts/generate_html_report.py",
    "i18n:verify": "node scripts/verify-translation-parity.mjs",
    "openapi:generate": "openapi-typescript ../../apps/backend/openapi.json -o lib/types/api.generated.ts",
    "e2e": "playwright test --project=flows",
    "e2e:smoke": "playwright test --project=smoke",
    "e2e:flows": "playwright test --project=flows",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@deqah/api-client": "workspace:*",
    "@deqah/shared": "workspace:*",
    "@deqah/ui": "workspace:*",
    "@hcaptcha/react-hcaptcha": "^1.17.4",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@radix-ui/react-direction": "^1.1.1",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "jose": "^4.15.9",
    "motion": "^12.38.0",
    "next": "^15.5.16",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@deqah/test-helpers-pw": "workspace:*",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "eslint-plugin-boundaries": "^6.0.1",
    "jsdom": "^20.0.3",
    "openapi-typescript": "^7.13.0",
    "pg": "^8.20.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
